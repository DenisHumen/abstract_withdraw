# --- Ключи API сторонних сервисов НЕ используются (Etherscan/abscan/Relay-key НЕ нужны). ---

# Опц. шифрование приватников в БД (не используется по умолчанию: ключи живут только в XLSX).
WALLET_ENCRYPTION_KEY=

# Публичные RPC-пулы (через запятую) — открытые ноды, без ключей.
# Первый в списке — основной, остальные — для ротации при сбое/лимите.
ABSTRACT_RPC_URLS=https://api.mainnet.abs.xyz
BASE_RPC_URLS=https://mainnet.base.org,https://base.publicnode.com,https://base.llamarpc.com

# AdsPower (ЕДИНСТВЕННЫЙ возможный ключ; только для fallback-ветки, пока не требуется).
ADSPOWER_API_KEY=
ADSPOWER_BASE_URL=http://local.adspower.net:50325
